rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all default safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Access permissions for CTC entities
    match /ctc_users/{userId} {
      allow read, write: if true;
    }

    match /ctc_catalog/{itemId} {
      allow read, write: if true;
    }

    match /ctc_questions/{questionId} {
      allow read, write: if true;
    }

    match /ctc_messages/{messageId} {
      allow read, write: if true;
    }

    match /ctc_schedules/{scheduleId} {
      allow read, write: if true;
    }

    match /ctc_settings/{settingId} {
      allow read, write: if true;
    }
  }
}
